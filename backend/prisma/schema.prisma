generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int          @id @default(autoincrement())
  name      String
  email     String       @unique
  password  String
  createdAt DateTime     @default(now())
  activate  Boolean      @default(true)
  access    String

  profile   UserProfile?
}

model UserProfile {
  id       Int     @id @default(autoincrement())
  photo    String?
  banner   String?
  config   Json?
  userId   Int     @unique
  user     User    @relation(fields: [userId], references: [id])
}